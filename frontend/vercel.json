{
  "version": 2,
  "buildCommand": "yarn build",
  "outputDirectory": "build",
  "devCommand": "yarn start",
  "framework": "create-react-app",
  "functions": {
    "api/binance-proxy.js": {
      "maxDuration": 30,
      "memory": 128,
      "runtime": "nodejs20.x"
    }
  },
  "regions": ["sin1"],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
